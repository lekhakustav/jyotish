# Local backend configuration. Copy to .env.local and fill real values.
# Never commit .env.local.

OPENAI_API_KEY=your-openai-api-key

# Backend agent defaults for the future Jyotish Pandit service.
OPENAI_JYOTISH_AGENT_MODEL=gpt-5.4-mini
OPENAI_JYOTISH_AGENT_PLANNER_MODEL=gpt-5-nano
JYOTISH_AGENT_PORT=8788
JYOTISH_AGENT_ENDPOINT_URL=https://ghfcssxptpazfbtiwshz.supabase.co/functions/v1/jyotish-agent

# Server-side voice/transcription. Never ship this key in the iOS app.
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_FEMALE_AGENT_ID=your-elevenlabs-female-agent-id
ELEVENLABS_MALE_AGENT_ID=your-elevenlabs-male-agent-id

# iOS client Supabase config. The publishable key is safe for the app when RLS is enabled.
SUPABASE_URL=https://ghfcssxptpazfbtiwshz.supabase.co
SUPABASE_ANON_OR_PUBLISHABLE_KEY=your-supabase-publishable-key

# Server/admin only. Never put this in the iOS app, Info.plist, or Xcode build settings.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
