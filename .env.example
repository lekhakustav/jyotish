# Local backend configuration. Copy to .env.local and fill real values.
# Never commit .env.local.

OPENAI_API_KEY=your-openai-api-key

# Backend agent defaults for the future Jyotish Pandit service.
OPENAI_JYOTISH_AGENT_MODEL=gpt-5-mini
OPENAI_JYOTISH_AGENT_PLANNER_MODEL=gpt-5-nano
JYOTISH_AGENT_PORT=8788

# iOS client Supabase config. The publishable key is safe for the app when RLS is enabled.
SUPABASE_URL=https://ghfcssxptpazfbtiwshz.supabase.co
SUPABASE_ANON_OR_PUBLISHABLE_KEY=your-supabase-publishable-key

# Server/admin only. Never put this in the iOS app, Info.plist, or Xcode build settings.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
