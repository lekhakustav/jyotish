    "web:preview": "vite preview --host 127.0.0.1",
    "web:server": "node server/index.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "^57.0.3",
    "@google/genai": "^2.10.0",
    "@supabase/supabase-js": "^2.110.1",
    "@vitejs/plugin-react": "latest",
    "astronomy-engine": "latest",
    "concurrently": "latest",
    "dotenv": "latest",
    "expo": "^57.0.2",
    "expo-audio": "^57.0.0",
    "expo-auth-session": "^57.0.2",
    "expo-crypto": "^57.0.0",
    "expo-font": "^57.0.0",
    "expo-haptics": "^57.0.0",
    "expo-router": "^57.0.3",
    "expo-secure-store": "^57.0.0",
    "expo-speech": "^57.0.0",
    "expo-status-bar": "^57.0.0",
    "expo-system-ui": "^57.0.0",
    "expo-web-browser": "^57.0.0",
    "express": "latest",
    "framer-motion": "latest",
    "jspdf": "^4.2.1",
    "lucide-react": "latest",
