{
  "name": "jyotish-edo-app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "type": "module",
  "scripts": {
    "android": "expo run:android",
    "android:prebuild": "expo prebuild --platform android",
    "android:export": "expo export --platform android",
    "typecheck": "tsc --noEmit",
    "start": "expo start",
    "web:dev": "concurrently -k \"node server/index.js\" \"vite --host 127.0.0.1\"",
