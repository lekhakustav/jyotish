    "react-dom": "latest",
    "react-native": "^0.86.0",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-web": "^0.21.2",
    "sweph": "^2.10.3-5",
    "tz-lookup": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "playwright": "^1.61.0",
    "typescript": "^6.0.3"
