{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sodhera.com/schemas/jyotish-marketing-veo-prompt-v1.json",
  "title": "Veo scene and edit recipe",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "prompt_id", "concept_id", "title", "objective", "audience_role", "market_id", "language", "scene", "post_production", "claims", "status", "created_at_utc"],
  "properties": {
    "schema_version": {"const": 1},
    "prompt_id": {"type": "string", "pattern": "^prm_[0-9]{8}_[a-z0-9]{6,12}$"},
    "concept_id": {"type": "string", "pattern": "^cpt_[0-9]{8}_[a-z0-9]{6,12}$"},
    "title": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "audience_role": {"type": "string", "minLength": 1},
    "market_id": {"type": "string", "minLength": 1},
    "language": {"type": "string", "minLength": 2},
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duration_seconds", "aspect_ratio", "generation_prompt", "negative_constraints"],
      "properties": {
        "duration_seconds": {"enum": [8, 12]},
        "aspect_ratio": {"const": "9:16"},
        "generation_prompt": {"type": "string", "minLength": 40},
        "negative_constraints": {"type": "array", "items": {"type": "string"}}
      }
    },
    "post_production": {
      "type": "object",
      "additionalProperties": false,
      "required": ["voiceover", "caption_text", "app_proof_feature", "cta", "timeline"],
      "properties": {
        "voiceover": {"type": "string"},
        "caption_text": {"type": "string"},
        "app_proof_feature": {"type": "string", "minLength": 1},
        "cta": {"type": "string", "minLength": 1},
        "timeline": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["start_ms", "end_ms", "layer", "instruction"],
            "properties": {
              "start_ms": {"type": "integer", "minimum": 0},
              "end_ms": {"type": "integer", "minimum": 1},
              "layer": {"type": "string", "minLength": 1},
              "instruction": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "claims": {"type": "array", "items": {"type": "string"}},
    "status": {"enum": ["draft", "approved", "generated", "retired", "rejected"]},
    "created_at_utc": {"type": "string", "format": "date-time"},
    "supersedes_prompt_id": {"type": ["string", "null"], "pattern": "^prm_[0-9]{8}_[a-z0-9]{6,12}$"}
  }
}
