{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sodhera.com/schemas/jyotish-marketing-experiment-plan-v1.json",
  "title": "Jyotish Baje marketing experiment plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "experiment_id", "title", "status", "hypothesis", "design_type",
    "causal_claim_allowed", "assignment_unit", "campaign_id", "audience_id", "population",
    "independent_variable", "arms", "primary_metric", "secondary_metrics", "guardrail_metrics",
    "alpha", "power", "planned_sample_per_arm", "minimum_duration_days",
    "maximum_duration_days", "stopping_rule", "exclusion_rules", "analysis_method",
    "multiple_testing_method", "attribution", "data_maturity_rule", "owner", "created_at_utc"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "experiment_id": {"$ref": "#/$defs/experiment_id"},
    "title": {"type": "string", "minLength": 1},
    "status": {"enum": ["draft", "planned", "running", "paused", "completed", "cancelled"]},
    "hypothesis": {"type": "string", "minLength": 20},
    "design_type": {"enum": ["platform_split_test", "randomized_holdout", "aa_test", "organic_observational", "matched_observational", "optimized_delivery_observational"]},
    "causal_claim_allowed": {"type": "boolean"},
    "assignment_unit": {"type": "string", "minLength": 1},
    "campaign_id": {"$ref": "#/$defs/campaign_id"},
    "audience_id": {"$ref": "#/$defs/audience_id"},
    "population": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "market_id", "app_platform", "inclusion", "exclusions"],
      "properties": {
        "platform": {"enum": ["instagram", "tiktok", "facebook", "youtube_shorts", "cross_platform"]},
        "market_id": {"type": "string", "minLength": 1},
        "app_platform": {"enum": ["ios", "android", "both"]},
        "inclusion": {"type": "array", "items": {"type": "string"}},
        "exclusions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "independent_variable": {"type": "string", "minLength": 1},
    "arms": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["arm_id", "label", "creative_ids", "traffic_weight"],
        "properties": {
          "arm_id": {"$ref": "#/$defs/arm_id"},
          "label": {"type": "string", "minLength": 1},
          "creative_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/creative_id"}},
          "traffic_weight": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
        }
      }
    },
    "primary_metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_key", "window", "baseline", "minimum_detectable_effect_absolute", "minimum_detectable_effect_relative"],
      "properties": {
        "metric_key": {"type": "string", "minLength": 1},
        "window": {"type": "string", "minLength": 1},
        "baseline": {"type": ["number", "null"]},
        "minimum_detectable_effect_absolute": {"type": ["number", "null"]},
        "minimum_detectable_effect_relative": {"type": ["number", "null"]}
      }
    },
    "secondary_metrics": {"type": "array", "items": {"type": "string"}},
    "guardrail_metrics": {"type": "array", "items": {"type": "string"}},
    "alpha": {"type": "number", "exclusiveMinimum": 0, "maximum": 0.1},
    "power": {"type": "number", "minimum": 0.7, "maximum": 0.99},
    "planned_sample_per_arm": {"type": ["integer", "null"], "minimum": 1},
    "minimum_duration_days": {"type": "integer", "minimum": 1},
    "maximum_duration_days": {"type": "integer", "minimum": 1},
    "planned_start_at_utc": {"type": ["string", "null"], "format": "date-time"},
    "planned_end_at_utc": {"type": ["string", "null"], "format": "date-time"},
    "stopping_rule": {"type": "string", "minLength": 10},
    "exclusion_rules": {"type": "array", "items": {"type": "string"}},
    "analysis_method": {"type": "string", "minLength": 5},
    "multiple_testing_method": {"enum": ["none_primary_only", "benjamini_hochberg", "holm", "other_predeclared"]},
    "attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "click_window_days", "view_window_days", "modeled_conversions_allowed"],
      "properties": {
        "model": {"enum": ["none", "platform_reported", "click_through", "view_through", "skan", "modeled", "mmp"]},
        "click_window_days": {"type": ["integer", "null"], "minimum": 0},
        "view_window_days": {"type": ["integer", "null"], "minimum": 0},
        "modeled_conversions_allowed": {"type": "boolean"}
      }
    },
    "data_maturity_rule": {"type": "string", "minLength": 10},
    "owner": {"type": "string", "minLength": 1},
    "created_at_utc": {"type": "string", "format": "date-time"},
    "notes": {"type": "string"}
  },
  "$defs": {
    "experiment_id": {"type": "string", "pattern": "^exp_[0-9]{8}_[a-z0-9]{6,12}$"},
    "arm_id": {"type": "string", "pattern": "^arm_[0-9]{8}_[a-z0-9]{6,12}$"},
    "campaign_id": {"type": "string", "pattern": "^cmp_[0-9]{8}_[a-z0-9]{6,12}$"},
    "audience_id": {"type": "string", "pattern": "^aud_[0-9]{8}_[a-z0-9]{6,12}$"},
    "creative_id": {"type": "string", "pattern": "^crv_[0-9]{8}_[a-z0-9]{6,12}$"}
  }
}
